<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shineofeidos.demo.mapper.MallProductMapper">

    <resultMap id="ProductMap" type="com.shineofeidos.demo.model.MallProduct">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="price" column="price"/>
        <result property="coverUrl" column="cover_url"/>
        <result property="category" column="category"/>
        <result property="stock" column="stock"/>
        <result property="description" column="description"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="countByCategory" resultType="long">
        SELECT COUNT(*)
        FROM mall_product
        <where>
            <if test="category != null and category != ''">
                category = #{category}
            </if>
        </where>
    </select>

    <select id="findPage" resultMap="ProductMap">
        SELECT id, name, price, cover_url, category, stock, description, created_at, updated_at
        FROM mall_product
        <where>
            <if test="category != null and category != ''">
                category = #{category}
            </if>
        </where>
        ORDER BY id
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="findById" resultMap="ProductMap">
        SELECT id, name, price, cover_url, category, stock, description, created_at, updated_at
        FROM mall_product
        WHERE id = #{id}
    </select>

    <select id="countCategories" resultType="com.shineofeidos.demo.model.MallCategoryDto">
        SELECT category AS category,
               CASE category
                   WHEN 'digital' THEN '数码'
                   WHEN 'life' THEN '生活'
                   WHEN 'fashion' THEN '服饰'
                   ELSE category
               END AS name,
               COUNT(*) AS count
        FROM mall_product
        GROUP BY category
        ORDER BY category
    </select>

</mapper>
