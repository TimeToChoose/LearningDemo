<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shineofeidos.demo.mapper.ItemMapper">

    <resultMap id="ItemMap" type="com.shineofeidos.demo.model.Item">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="category" column="category"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findAll" resultMap="ItemMap">
        SELECT id, name, category, created_at, updated_at
        FROM demo_item
        ORDER BY id
    </select>

    <select id="findById" resultMap="ItemMap">
        SELECT id, name, category, created_at, updated_at
        FROM demo_item
        WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO demo_item (name, category)
        VALUES (#{name}, #{category})
    </insert>

    <update id="update">
        UPDATE demo_item
        SET name = #{name}, category = #{category}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM demo_item WHERE id = #{id}
    </delete>

</mapper>
