# ngrok 固定域名需付费 Reserved Domain
# 复制为 ngrok.yml：cp tunnel/ngrok.yml.example tunnel/ngrok.yml
# 在 https://dashboard.ngrok.com 获取 authtoken 和 reserved domain

version: "2"
authtoken: YOUR_NGROK_AUTHTOKEN

tunnels:
  learning-demo:
    proto: http
    addr: 8080
    # 付费后在 dashboard 创建 Reserved Domain 后填写，例如：
    # domain: learning-demo.ngrok-free.app
