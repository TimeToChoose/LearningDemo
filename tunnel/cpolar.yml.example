# 复制为 cpolar.yml 并填入你的 authtoken
# cp tunnel/cpolar.yml.example tunnel/cpolar.yml
#
# 固定域名步骤（cpolar 官网 https://www.cpolar.com）：
# 1. 注册并登录 → 验证邮箱
# 2. 左侧「预留」→「保留二级子域名」→ 填子域名（如 learningdemo）→ 地区选 China
# 3. 左侧「认证」→ 复制 authtoken 到下方
# 4. Android 固定 BaseUrl 示例：https://learningdemo.vip.cpolar.cn

authtoken: YOUR_CPOLAR_AUTHTOKEN

tunnels:
  learning-demo:
    proto: http
    addr: 8080
  # 若已预留子域名，取消下面注释并改成你的子域名
  # learning-demo-fixed:
  #   proto: http
  #   addr: 8080
  #   subdomain: learningdemo
  #   region: cn
